pipeline {
  agent {
    docker {
      image 'laxmangodi/maven-laxman-docker-agent:v1'  // YOUR IMAGE! ✅
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }
  stages {
    stage('Laxman Verify') {
      steps {
        sh 'whoami && hostname && docker version && mvn --version'
      }
    }
    stage('Build Spring Boot') {
      steps {
        sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn clean package'
      }
    }
  }
}
